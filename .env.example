# Development Environment Variables
# Copy this to .env and fill in values
# DO NOT commit .env to git — it contains secrets

# Database
# For Docker: postgres://postgres:postgres@localhost:5432/doit
# For local PostgreSQL: postgres://user:password@localhost:5432/doit
DATABASE_URL=postgres://postgres:1234@localhost:5432/doit

# JWT Secret (minimum 32 bytes / 256 bits)
# Generate with: head -c 32 /dev/urandom | base64
# MUST be different from production!
JWT_SECRET=

# Environment
ENVIRONMENT=development

# Logging (debug, info, warn, error)
LOG_LEVEL=info

# Server Ports
PORT=8080